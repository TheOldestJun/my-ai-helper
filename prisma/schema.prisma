// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Prisma schema - Схема базы данных
// Описывает структуру всех таблиц и отношений между ними

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

/**
 * User - Пользователи системы
 * Роли: APPLICANT (заявитель), DIRECTOR (директор), SUPPLY (снабжение),
 *       WAREHOUSE (склад), KITCHEN (кухня), ADMIN (администратор)
 */
model User {
  id                String         @id @default(cuid())
  email             String         @unique
  password          String
  firstName         String?
  lastName          String?
  roles             UserRole[]
  orders            Order[]
  statusChangedProducts OrderProduct[] @relation("StatusChanger")
  statusHistory     OrderStatusHistory[]
  orderHistory      OrderHistory[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Role {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  users       UserRole[]
  createdAt   DateTime    @default(now())
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

model Unit {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String?
  symbol        String
  products      ProductUnit[]
  orderProducts OrderProduct[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Product {
  id            String         @id @default(cuid())
  name          String
  description   String?
  sku           String?        @unique
  units         ProductUnit[]
  orderProducts OrderProduct[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProductUnit {
  id        String   @id @default(cuid())
  productId String
  unitId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, unitId])
}

model Order {
  id             String         @id @default(cuid())
  number         String         @unique
  priority       OrderPriority  @default(NORMAL)
  notes          String?
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  archivedAt     DateTime?
  products       OrderProduct[]
  history        OrderHistory[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([archivedAt])
}

model OrderProduct {
  id             String      @id @default(cuid())
  orderId        String
  productId      String
  quantity       Float
  unitId         String
  status         OrderStatus @default(PENDING)
  notes          String?
  statusChangedById String?
  statusChangedBy User?       @relation("StatusChanger", fields: [statusChangedById], references: [id])
  statusChangedAt DateTime?
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit           Unit        @relation(fields: [unitId], references: [id])
  createdAt      DateTime    @default(now())

  @@unique([orderId, productId, unitId])
  @@index([status])
  statusHistory OrderStatusHistory[]
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderProductId String
  oldStatus   OrderStatus
  newStatus   OrderStatus
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  changedAt   DateTime    @default(now())
  orderProduct OrderProduct @relation(fields: [orderProductId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@index([orderProductId])
}

model OrderHistory {
  id          String      @id @default(cuid())
  orderId     String
  action      String      // 'APPROVED', 'REJECTED', 'ARCHIVED'
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  changedAt   DateTime    @default(now())
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason      String?     // For rejection
  createdAt   DateTime    @default(now())

  @@index([orderId])
}

model Dish {
  id        String   @id @default(cuid())
  name      String   @unique
  type      DishType @default(SOUP)
  price     Float    @default(0)
  createdAt DateTime @default(now())
}

enum DishType {
  SOUP
  GARNISH
  MEAT
  SALAD
  BAKERY
  DRINK
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  ORDERED
  PAID
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum OrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
