# MySQL connection string
DATABASE_URL=mysql://user:password@host:3306/database_name
# Shadow DB for Prisma migrations (usually same server, different DB name)
SHADOW_DATABASE_URL=mysql://user:password@host:3306/database_name_shadow
# JWT secret key for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-change-in-production
